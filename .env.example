# Rubberduck - Local-First Digital Forensic Platform
# Copy to .env and customize

# Data directories (relative to project root)
DATA_DIR=./data
ORIGINALS_DIR=./data/originals
PARSED_DIR=./data/parsed
EXPORTS_DIR=./data/exports
OSINT_DIR=./data/osint_captures
PARQUET_DIR=./data/parquet

# Database paths
SQLITE_PATH=./data/rubberduck.db
DUCKDB_PATH=./data/rubberduck.duckdb

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/rubberduck.log

# spaCy model
SPACY_MODEL=en_core_web_sm

# OCR (Tesseract)
TESSERACT_CMD=tesseract
OCR_ENABLED=true

# Default timezone for naive timestamps (IANA format)
DEFAULT_TIMEZONE=America/Los_Angeles

# Case defaults
DEFAULT_COURT=San Francisco Superior Court, Probate Division

# Max concurrent background jobs
MAX_WORKERS=4

# Max archive nesting depth
MAX_ARCHIVE_DEPTH=5

# Chunk size for file hashing (bytes)
HASH_CHUNK_SIZE=65536
